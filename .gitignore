# =============================================================================
# .gitignore — Arquivos que o git deve ignorar
# =============================================================================

# -----------------------------------------------------------------------------
# GERADO AUTOMATICAMENTE — nunca commitar
# -----------------------------------------------------------------------------
# setuptools-scm grava a versão aqui a cada "pip install -e ."
# Commitar este arquivo causaria conflitos e derrotaria o propósito do scm.
app/__version__.py

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
dist/
build/

# -----------------------------------------------------------------------------
# Ambiente virtual
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/

# -----------------------------------------------------------------------------
# Testes e cobertura
# -----------------------------------------------------------------------------
.coverage
.coverage.*
htmlcov/
.pytest_cache/
*.xml          # relatórios junit

# -----------------------------------------------------------------------------
# Ferramentas de desenvolvimento
# -----------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/
.pre-commit-cache/

# -----------------------------------------------------------------------------
# Banco de dados local (gerado pelo app em produção)
# -----------------------------------------------------------------------------
*.db
backups/

# -----------------------------------------------------------------------------
# Executável gerado pelo PyInstaller
# -----------------------------------------------------------------------------
*.spec
app/dist/
app/build/

# -----------------------------------------------------------------------------
# Logs do app
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
